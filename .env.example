# 식집사들 local environment example
# Copy values into your shell, frontend/.env, or deployment environment as needed.
# Do not commit real secrets.

# Frontend
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Backend server
SERVER_PORT=8080

# Backend datasource - local default uses in-memory H2.
# For MySQL, override these values in your local environment.
SPRING_DATASOURCE_URL=jdbc:h2:mem:sikjipsa;MODE=MySQL;DATABASE_TO_LOWER=TRUE;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# S3-compatible object storage example.
# Local development can use MinIO. Production can use AWS S3, Cloudflare R2, Supabase Storage, etc.
APP_STORAGE_BUCKET=sikjipsa-dev
APP_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/sikjipsa-dev

# Reserved for future storage implementation.
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=replace_me
# S3_SECRET_KEY=replace_me
# S3_REGION=ap-northeast-2
